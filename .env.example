# =============================================================================
# Rental911 — Environment Variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must NEVER be committed.
# =============================================================================

# ---- Supabase (Database + Auth) --------------------------------------------
# Project URL and anon key are safe to expose to the browser (NEXT_PUBLIC_*).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key bypasses RLS — SERVER ONLY. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- App --------------------------------------------------------------------
# Public base URL of the deployment (used for auth redirects, receipts, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Stripe (Phase 2 — rent collection + Connect Express) -------------------
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Platform fee applied to every rent payment (2.5%).
PLATFORM_FEE_PERCENT=2.5

# ---- Anthropic (maintenance chat summaries) ---------------------------------
ANTHROPIC_API_KEY=sk-ant-xxx
# Model used to summarize closed maintenance threads.
ANTHROPIC_SUMMARY_MODEL=claude-sonnet-4-6

# ---- GoHighLevel (CRM sync + Calendar) --------------------------------------
GHL_API_KEY=your-ghl-api-key
GHL_LOCATION_ID=your-ghl-location-id
# Public iframe embed URL for Christine's onboarding-call booking calendar (Step 8).
NEXT_PUBLIC_GHL_ONBOARDING_CALENDAR_EMBED=https://api.leadconnectorhq.com/widget/booking/your-calendar-id
# Hardcoded CRM link shown in the admin sidebar.
NEXT_PUBLIC_GHL_CRM_URL=https://app.gohighlevel.com

# ---- LeaseRunner (tenant screening — Phase 5, placeholder) ------------------
LEASERUNNER_API_KEY=tbd
LEASERUNNER_API_BASE=https://api.leaserunner.com
